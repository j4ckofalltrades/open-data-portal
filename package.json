{
  "name": "open-data-portal",
  "version": "1.0.0",
  "description": "Open Data Portal and API for exploring public datasets",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "pnpm run build && wrangler deploy",
    "lint": "biome check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "db:migrate:remote": "wrangler d1 migrations apply open-data-db --remote",
    "db:migrate:local": "wrangler d1 migrations apply open-data-db --local",
    "db:init": "tsx scripts/init-db.ts",
    "db:init:local": "pnpm run db:init && wrangler d1 execute open-data-db --local --file=./scripts/init.sql",
    "db:init:remote": "pnpm run db:init && wrangler d1 execute open-data-db --remote --file=./scripts/init.sql",
    "prepare": "husky"
  },
  "dependencies": {
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^0.18.4",
    "@tailwindcss/postcss": "^4.2.1",
    "axios": "^1.13.6",
    "hono": "^4.12.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1",
    "react-router-dom": "^7.13.1",
    "swr": "^2.4.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@cloudflare/vite-plugin": "^1.27.0",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/ui": "^4.0.18",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "lucide-react": "^0.577.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "wrangler": "4.72.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
